---
config:
  flowchart:
    curve: linear
---
graph TD;
    __start__([<p>__start__</p>]):::startNode
    generate_gherkin(generate_gherkin):::process
    validate_gherkin(validate_gherkin):::decision
    write_tests(write_tests):::process
    __end__([<p>__end__</p>]):::endNode

    __start__ --> generate_gherkin;
    generate_gherkin --> validate_gherkin;
    validate_gherkin -. end .-> __end__;
    validate_gherkin -. proceed .-> write_tests;
    write_tests --> __end__;

    %% Styles
    classDef startNode fill:#E0F7FA,stroke:#00796B,stroke-width:2px,color:#004D40
    classDef process fill:#E8EAF6,stroke:#3F51B5,stroke-width:2px,color:#1A237E
    classDef decision fill:#FFF3E0,stroke:#FB8C00,stroke-width:2px,color:#E65100
    classDef endNode fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
